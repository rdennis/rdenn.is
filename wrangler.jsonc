{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"compatibility_date": "2026-06-20",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "rdenn-is",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"routes": [
		{
			"pattern": "rdenn.is",
			"custom_domain": true,
		},
	],
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	}
}